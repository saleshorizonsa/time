NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-long-random-secret

# PostgreSQL / Supabase database
# Option A: paste the complete connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/time_attendance
DATABASE_SSL=false
DATABASE_POOL_MAX=10

# Option B: Supabase project settings. If DATABASE_URL is empty, the app builds
# a pooled Supabase Postgres URL from these values.
SUPABASE_URL=https://ldkudwluqfupxngdnvcd.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_PROJECT_REF=ldkudwluqfupxngdnvcd
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=aws-1-ap-northeast-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_USER=postgres.ldkudwluqfupxngdnvcd
SUPABASE_DB_NAME=postgres

# Initial admin account created on first server start
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Microsoft Access / ODBC
ACCESS_DB_PATH=\\\\REMOTE-PC\\SharedFolder\\attendance.accdb
ACCESS_DRIVER={Microsoft Access Driver (*.mdb, *.accdb)}
ACCESS_DB_PASSWORD=
ACCESS_UID=
ACCESS_PWD=
ACCESS_TABLE=AttendanceLog

# Optional source column names in the Access table
ACCESS_EMPLOYEE_ID_COLUMN=EmployeeID
ACCESS_EMPLOYEE_NAME_COLUMN=EmployeeName
ACCESS_DEPARTMENT_COLUMN=Department
ACCESS_SHIFT_COLUMN=ShiftName
ACCESS_CHECK_IN_COLUMN=CheckInTime
ACCESS_CHECK_OUT_COLUMN=CheckOutTime
ACCESS_STATUS_COLUMN=Status
ACCESS_OVERTIME_MINUTES_COLUMN=OvertimeMinutes

# Remote path and sync
REMOTE_HOST=REMOTE-PC
REMOTE_SHARE=\\\\REMOTE-PC\\SharedFolder
SYNC_FREQUENCY_CRON=*/15 * * * *
SYNC_LOOKBACK_DAYS=30

# ZKTeco MB20
# Use ADMS push as primary when the remote site has no PC.
ZK_MODE=adms
ZK_ADMS_SERVER_ADDRESS=attendance.yourdomain.com
ZK_ADMS_SERVER_PORT=443
ZK_ADMS_HTTPS=true

# Direct pull fallback. Requires remote router port forwarding or VPN.
ZK_DEVICE_HOST=
ZK_DEVICE_PORT=4370
ZK_DEVICE_PASSWORD=0
ZK_DEVICE_TIMEOUT_MS=10000
ZK_DEVICE_INPORT=5200
ZK_TIMEZONE=Asia/Riyadh

# Mobile punch workplace geofence
WORKPLACE_NAME=Main Workplace
WORKPLACE_LATITUDE=
WORKPLACE_LONGITUDE=
WORKPLACE_RADIUS_METERS=500
