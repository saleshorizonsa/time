NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# REQUIRED in production: generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-long-random-secret

# ── Database ────────────────────────────────────────────────────────────────
# Option A: full connection string (recommended for local/self-hosted)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/time_attendance
DATABASE_SSL=false
DATABASE_POOL_MAX=10

# Option B: Supabase project settings
# If DATABASE_URL is empty, the server builds a pooled URL from these values.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_USER=
SUPABASE_DB_NAME=postgres

# ── Admin account ────────────────────────────────────────────────────────────
# REQUIRED in production. Created on first start if not already in DB.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# ── Microsoft Access / ODBC ──────────────────────────────────────────────────
ACCESS_DB_PATH=\\\\REMOTE-PC\\SharedFolder\\attendance.accdb
ACCESS_DRIVER={Microsoft Access Driver (*.mdb, *.accdb)}
ACCESS_DB_PASSWORD=
ACCESS_UID=
ACCESS_PWD=
ACCESS_TABLE=AttendanceLog

# Column name mapping (match your Access table schema)
ACCESS_EMPLOYEE_ID_COLUMN=EmployeeID
ACCESS_EMPLOYEE_NAME_COLUMN=EmployeeName
ACCESS_DEPARTMENT_COLUMN=Department
ACCESS_SHIFT_COLUMN=ShiftName
ACCESS_CHECK_IN_COLUMN=CheckInTime
ACCESS_CHECK_OUT_COLUMN=CheckOutTime
ACCESS_STATUS_COLUMN=Status
ACCESS_OVERTIME_MINUTES_COLUMN=OvertimeMinutes

# ── Sync schedule ────────────────────────────────────────────────────────────
REMOTE_HOST=REMOTE-PC
REMOTE_SHARE=\\\\REMOTE-PC\\SharedFolder
SYNC_FREQUENCY_CRON=*/15 * * * *
SYNC_LOOKBACK_DAYS=30

# ── ZKTeco MB20 ──────────────────────────────────────────────────────────────
# ZK_MODE=adms  → device pushes to /iclock/cdata (recommended for remote sites)
# ZK_MODE=pull  → server polls device directly on ZK_DEVICE_HOST:ZK_DEVICE_PORT
ZK_MODE=adms
ZK_ADMS_SERVER_ADDRESS=attendance.yourdomain.com
ZK_ADMS_SERVER_PORT=443
ZK_ADMS_HTTPS=true

ZK_DEVICE_HOST=
ZK_DEVICE_PORT=4370
ZK_DEVICE_PASSWORD=0
ZK_DEVICE_TIMEOUT_MS=10000
ZK_DEVICE_INPORT=5200
ZK_TIMEZONE=Asia/Riyadh

# ── Mobile punch geofence ────────────────────────────────────────────────────
WORKPLACE_NAME=Main Workplace
WORKPLACE_LATITUDE=
WORKPLACE_LONGITUDE=
WORKPLACE_RADIUS_METERS=500
